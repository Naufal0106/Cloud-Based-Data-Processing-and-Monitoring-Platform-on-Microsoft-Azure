# ===============================
# Terraform
# ===============================
.terraform/
**/.terraform/

# Commit .terraform.lock.hcl for provider reproducibility.
*.tfstate
*.tfstate.*
terraform.tfstate*
*.terraform.tfstate.lock.info
*.tfplan
*.plan
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Sensitive Terraform variables
*.tfvars
*.tfvars.json

# Terraform source and provider lock file are committed as IaC evidence.
# Keep secret values in *.tfvars and state/plan files only; those stay ignored above.

# ===============================
# Secrets / Credentials
# ===============================
.env
.env.*
!.env.example
!.env.*.example

.dev.vars
.dev.vars.*
!.dev.vars.example

local.settings.json
.local.settings.json
src/dashboard/env.js

*.pem
*.key
*.pfx
*.p12
*.crt
*.cer
*credentials*.json
*credential*.json
*secret*.json
azureProfile.json
secrets/*
!secrets/.gitkeep
!secrets/*.example.ps1
!secrets/*.example.env

