# ===============================
# Terraform
# ===============================
.terraform/
**/.terraform/

# Commit .terraform.lock.hcl for provider reproducibility.
*.tfstate
*.tfstate.*
terraform.tfstate*
*.terraform.tfstate.lock.info
*.tfplan
*.plan
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Sensitive Terraform variables
*.tfvars
*.tfvars.json

# Terraform source for this project is kept out of the public repo.
infra/*.tf
infra/*.tf.json
infra/.terraform.lock.hcl

# ===============================
# Secrets / Credentials
# ===============================
.env
.env.*
!.env.example
!.env.*.example

.dev.vars
.dev.vars.*
!.dev.vars.example

local.settings.json
.local.settings.json
src/dashboard/env.js

*.pem
*.key
*.pfx
*.p12
*.crt
*.cer
*credentials*.json
*credential*.json
*secret*.json
azureProfile.json

# ===============================
# Python / Azure Functions
# ===============================
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.ruff_cache/
.mypy_cache/
.venv/
venv/
env/
.python_packages/

# ===============================
# Node / Cloudflare
# ===============================
node_modules/
.wrangler/
.pages/
dist/
build/
artifacts/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

